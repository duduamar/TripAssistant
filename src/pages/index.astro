---
import { stat } from 'node:fs/promises';
import { resolve } from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import TopTabs from '../components/TopTabs.astro';
import { appConfig } from '../config/app';
import { parseTripMarkdown, renderMarkdown } from '../lib/trip';
import { dayRoute, summarizeDay, truncateText } from '../lib/ui';
import rawMarkdown from '../content/trips/wa-mt-id-roadtrip.md?raw';
import '../styles/trip.css';

const markdownPath = resolve('src/content/trips/wa-mt-id-roadtrip.md');
const fileStats = await stat(markdownPath);

const trip = parseTripMarkdown(rawMarkdown);
const baseUrl = import.meta.env.BASE_URL;
const preambleHtml = renderMarkdown(trip.preambleMarkdown);
const days = trip.days.map((day) => ({
  ...day,
  shortTitle: truncateText(day.title, 64),
  preview: summarizeDay(day.markdown),
  href: dayRoute(baseUrl, day.number)
}));

const dayRoutes = days.map((day) => ({
  number: day.number,
  dateIso: day.dateIso,
  href: day.href
}));

const lastUpdated = new Intl.DateTimeFormat('en-US', {
  dateStyle: 'medium',
  timeStyle: 'short'
}).format(fileStats.mtime);
const rawAppVersion = String(import.meta.env.PUBLIC_APP_VERSION ?? 'local');
const appVersion = rawAppVersion.includes('-')
  ? `${rawAppVersion.split('-')[0]}-${rawAppVersion.split('-')[1]?.slice(0, 7) ?? ''}`
  : rawAppVersion;

const pageDescription = 'iPhone-friendly trip overview with day tabs and offline support.';
---

<BaseLayout title={trip.title} description={pageDescription}>
  <main class="shell" data-base-url={baseUrl}>
    <TopTabs days={days} active="overview" baseUrl={baseUrl} />

    <section class="card">
      <p class="eyebrow">Trip Assistant</p>
      <h1>{trip.title}</h1>
      <p class="meta-line">Last updated: {lastUpdated}</p>
      <p class="meta-line">Build: {appVersion}</p>
      <p class="meta-line">Mode: {appConfig.offlineMode} offline · {appConfig.mapProvider} maps</p>
      <div class="inline-links">
        <button class="button-link alt" type="button" id="today-button">Open Today</button>
      </div>
    </section>

    <section class="card day-grid" aria-label="Day pages">
      {days.map((day) => (
        <article class="day-summary">
          <div class="day-head">
            <p class="day-name">Day {day.number}</p>
            {day.dateText && <p class="day-date">{day.dateText}</p>}
          </div>
          <h2 class="day-title">{day.shortTitle}</h2>
          <p class="day-preview">{day.preview}</p>
          <div class="inline-links">
            <a class="button-link" href={day.href}>Open Day {day.number}</a>
          </div>
        </article>
      ))}
    </section>

    <details class="card">
      <summary><strong>Full Plan Reference</strong> (from markdown)</summary>
      <article class="trip-markdown" set:html={preambleHtml} />
    </details>
  </main>

  <script id="trip-day-routes" type="application/json" set:html={JSON.stringify(dayRoutes)}></script>
  <script>
    const routesNode = document.getElementById('trip-day-routes');
    const dayRoutes = routesNode ? JSON.parse(routesNode.textContent ?? '[]') : [];

    function localIsoToday() {
      const now = new Date();
      const yyyy = now.getFullYear();
      const mm = String(now.getMonth() + 1).padStart(2, '0');
      const dd = String(now.getDate()).padStart(2, '0');
      return `${yyyy}-${mm}-${dd}`;
    }

    function getSuggestedDayRoute() {
      const todayIso = localIsoToday();
      const exact = dayRoutes.find((day) => day.dateIso === todayIso);
      if (exact) {
        return exact.href;
      }

      const next = dayRoutes.find((day) => day.dateIso && day.dateIso > todayIso);
      if (next) {
        return next.href;
      }

      return dayRoutes[0]?.href;
    }

    const todayButton = document.getElementById('today-button');
    if (todayButton instanceof HTMLButtonElement) {
      todayButton.addEventListener('click', () => {
        const href = getSuggestedDayRoute();
        if (href) {
          window.location.href = href;
        }
      });
    }

    const appRoot = document.querySelector('.shell');
    const baseUrl = appRoot?.getAttribute('data-base-url') ?? '/';
    const fallbackUrl = `${baseUrl}offline-image.svg`;
    document.querySelectorAll('img').forEach((image) => {
      image.loading = 'lazy';
      image.decoding = 'async';

      image.addEventListener('error', () => {
        if (image.dataset.offlineHandled === 'yes') {
          return;
        }

        image.dataset.offlineHandled = 'yes';
        image.src = fallbackUrl;
        image.classList.add('offline-fallback');
        if (!image.alt) {
          image.alt = 'Image unavailable offline';
        }
      });
    });
  </script>
</BaseLayout>
